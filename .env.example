# AfriBench — Variables d'environnement
# Copiez ce fichier en .env ou exportez chaque variable dans votre shell.
# Toutes les clés sont optionnelles — seuls les modèles utilisés nécessitent leur clé.

# OpenAI (GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=sk-...

# Anthropic (Claude Sonnet 4, Claude Haiku 3.5)
ANTHROPIC_API_KEY=sk-ant-...

# Mistral AI (Mistral Large)
MISTRAL_API_KEY=...

# Google Gemini
GEMINI_API_KEY=...

# DeepSeek
DEEPSEEK_API_KEY=...

# Together AI (Llama, open models)
TOGETHER_API_KEY=...
